rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isRecent() {
      return request.time > timestamp.date(2026, 1, 1);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'result', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.result is string &&
             data.timestamp is timestamp;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['userId', 'pair', 'condition', 'value', 'isActive', 'isTriggered', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.pair is string &&
             data.condition in ['ABOVE', 'BELOW'] &&
             data.value is number &&
             data.isActive is bool &&
             data.isTriggered is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /analyses/{analysisId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAnalysis(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /alerts/{alertId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidAlert(request.resource.data);
      allow update: if isDocOwner() && isValidAlert(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
